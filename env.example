# Copy to .env (same folder as docker-compose.yml). Không commit .env.

# Docker Hub (trùng secrets.DOCKER_USERNAME trên GitHub Actions)
DOCKER_USERNAME=ducluong610

# URL trình duyệt mở frontend (OAuth redirect sau đăng nhập Google)
FRONTEND_URL=https://ducluong06.dpdns.org

# API public URL — phải trùng build-arg frontend & Google Console
NEXT_PUBLIC_API_URL=https://api.ducluong06.dpdns.org

# JWT (mỗi secret ≥ 32 ký tự)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Google OAuth — trùng Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.ducluong06.dpdns.org/auth/google/callback
